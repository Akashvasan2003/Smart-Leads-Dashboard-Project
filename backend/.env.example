# ─── App ───────────────────────────────────────────────
NODE_ENV=development

# ─── Server ────────────────────────────────────────────
# Railway injects PORT automatically in production, leave blank or remove
PORT=5000

# ─── Database ──────────────────────────────────────────
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-leads

# MongoDB Atlas (use this for production)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-leads

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────
# Local development
CORS_ORIGIN=http://localhost:5173

# Production (Railway frontend URL, no trailing slash)
# CORS_ORIGIN=https://your-frontend.up.railway.app

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
